# Copy this file to ".env" and fill in keys as you add features.
# The app runs fully on yfinance with NONE of these set.

# Enables the AI macro-narrative feature ("why did the market move?").
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model used for narratives (sonnet is cheap + fast for frequent updates).
NARRATIVE_MODEL=claude-sonnet-4-6

# Optional: richer macro / economic data (Treasury yields, CPI, rates...).
# Free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Optional: company news + fundamentals. Free tier at https://finnhub.io/
FINNHUB_API_KEY=

# Optional: Twelve Data — real-time quotes, charts & detail (https://twelvedata.com/).
# When set, it becomes the primary price source; yfinance is the automatic fallback.
TWELVE_DATA_API_KEY=

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000
